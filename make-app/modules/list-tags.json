{
  "name": "list_tags",
  "label": "List Tags",
  "description": "Returns all user-defined tags in your Convioo workspace. Use this as a data source for other modules.",
  "typeId": 4,
  "connection": "convioo-api-key",
  "communication": {
    "url": "{{connection.baseUrl}}/api/v1/tags",
    "method": "GET",
    "headers": {
      "Authorization": "Bearer {{connection.apiKey}}"
    },
    "response": {
      "output": "{{body.items}}",
      "error": {
        "message": "[{{statusCode}}] {{body.detail}}"
      }
    }
  },
  "parameters": [],
  "interface": [
    { "name": "id", "type": "text", "label": "Tag ID" },
    { "name": "name", "type": "text", "label": "Tag Name" },
    { "name": "color", "type": "text", "label": "Tag Color (hex)" }
  ],
  "sample": [
    { "id": "b1aaf5fe-2db5-4f0d-9c66-9c2b8b7c52a4", "name": "priority", "color": "#FF5630" },
    { "id": "c2bbf6ff-3ec6-5g1e-0d77-0d3c9c8d63b5", "name": "warm", "color": "#FFAB00" }
  ]
}
