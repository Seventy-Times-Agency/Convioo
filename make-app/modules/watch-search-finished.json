{
  "name": "watch_search_finished",
  "label": "Watch Search Finished",
  "description": "Triggers when a Convioo search completes (whether it found leads or failed).",
  "typeId": 1,
  "connection": "convioo-api-key",
  "webhook": {
    "attach": {
      "url": "{{connection.baseUrl}}/api/v1/webhooks",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {{connection.apiKey}}"
      },
      "body": {
        "url": "{{webhook.url}}",
        "events": ["search.finished"],
        "secret": "{{ifempty(webhook.sharedToken, randomString(32))}}"
      },
      "response": {
        "data": {
          "webhookId": "{{body.id}}"
        },
        "error": {
          "message": "[{{statusCode}}] {{body.detail}}"
        }
      }
    },
    "detach": {
      "url": "{{connection.baseUrl}}/api/v1/webhooks/{{webhook.data.webhookId}}",
      "method": "DELETE",
      "headers": {
        "Authorization": "Bearer {{connection.apiKey}}"
      }
    },
    "respond": {
      "status": 200,
      "body": "OK"
    },
    "condition": "{{body.event === 'search.finished'}}"
  },
  "output": "{{body.data.search}}",
  "interface": [
    { "name": "id", "type": "text", "label": "Search ID" },
    { "name": "user_id", "type": "integer", "label": "User ID" },
    { "name": "team_id", "type": "text", "label": "Team ID" },
    { "name": "niche", "type": "text", "label": "Niche / Business Type" },
    { "name": "region", "type": "text", "label": "Region" },
    { "name": "status", "type": "text", "label": "Status (finished/failed)" },
    { "name": "leads_count", "type": "integer", "label": "Leads Found" },
    { "name": "avg_score", "type": "number", "label": "Average AI Score" },
    { "name": "error", "type": "text", "label": "Error (null on success)" },
    { "name": "created_at", "type": "date", "label": "Started At" },
    { "name": "finished_at", "type": "date", "label": "Finished At" }
  ],
  "sample": {
    "id": "a45e6c1d-2c5b-4ab3-9d8e-89bb14f9b6a2",
    "user_id": 1,
    "team_id": null,
    "niche": "roofing companies",
    "region": "New York, NY",
    "status": "finished",
    "leads_count": 47,
    "avg_score": 64.2,
    "error": null,
    "created_at": "2026-05-03T10:00:00+00:00",
    "finished_at": "2026-05-03T10:11:14+00:00"
  }
}
