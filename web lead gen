        borderRadius: 14,
        borderTopLeftRadius: isBot ? 4 : 14,
        borderTopRightRadius: isBot ? 14 : 4,
        fontSize:13.5, lineHeight:1.5,
      }}>
        {msg.text.split('**').map((part, i) => i % 2 === 1 ? <b key={i}>{part}</b> : part)}
      </div>
    </div>
  );
}

