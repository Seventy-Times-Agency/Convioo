# =============================================================================
# VERCEL — FRONTEND ENVIRONMENT VARIABLES
# Copy to .env.local for local dev. On Vercel set each key in Project Settings → Environment Variables.
# =============================================================================

# =============================================================================
# ОБЯЗАТЕЛЬНЫЕ
# =============================================================================

# URL Railway-сервиса. Смотри: Railway → твой сервис → Settings → Networking → Public Domain.
# Пример: https://convioo-production-1234.up.railway.app
# ВАЖНО: без трейлинг-слеша.
NEXT_PUBLIC_API_URL=http://localhost:8080

# =============================================================================
# SENTRY (мониторинг ошибок)
# Пусто → SDK не инициализируется.
# =============================================================================

# Создать проект "convioo-web" (Next.js) на https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Опционально: загрузка source maps в Sentry при деплое на Vercel.
# Нужны все три переменные, иначе source maps остаются локально.
# SENTRY_AUTH_TOKEN — создать на https://sentry.io/settings/auth-tokens/
# SENTRY_ORG — slug организации в Sentry (видно в URL: sentry.io/organizations/<slug>/)
# SENTRY_PROJECT — имя проекта в Sentry (convioo-web)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=convioo-web
