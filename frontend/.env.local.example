# Convioo API endpoint — set to your Railway service URL.
# Example: https://convioo-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8080

# Sentry (frontend project). Empty = SDK never initialises.
# Create a "convioo-web" project on https://sentry.io and paste its
# ingest URL here.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Optional: source-map upload to Sentry. Set all three on the Vercel
# project to enable; missing any of them = source maps stay local.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=convioo-web
