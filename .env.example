# Telegram bot token from @BotFather
BOT_TOKEN=1234567890:AAA-replace-me

# Google Places API (New) key
# 1. https://console.cloud.google.com/ -> create project
# 2. APIs & Services -> Enable "Places API (New)"
# 3. Credentials -> Create API key
GOOGLE_PLACES_API_KEY=AIza-replace-me

# Postgres connection string.
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/leadgen
# Railway provides DATABASE_URL automatically when you add a Postgres plugin.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leadgen

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Per-user quota of searches (applies to newly created users)
DEFAULT_QUERIES_LIMIT=5

# Max leads fetched per search (Google Places returns up to 60 via pagination)
MAX_RESULTS_PER_QUERY=60

# --- AI enrichment (Anthropic Claude) ---
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-replace-me

# Claude model to use for analysis.
# Recommended (cheap + fast): claude-haiku-4-5-20251001
# Higher quality (more expensive): claude-sonnet-4-5 or claude-opus-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# How many top leads to enrich (fetch website, reviews, run AI) per query.
# Higher = better insights, higher cost per search.
MAX_ENRICH_LEADS=15

# Concurrency for parallel enrichment tasks (websites + AI calls).
ENRICH_CONCURRENCY=5
