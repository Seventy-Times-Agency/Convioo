# ===== Обязательные =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/convioo
GOOGLE_PLACES_API_KEY=replace_me

# ===== Рекомендуется (без ключа Anthropic используется fallback-режим) =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ===== Доступ =====
# Когда задано, регистрация на сайте требует ввода этого кода.
# Пусто = регистрация открыта (dev-режим).
REGISTRATION_PASSWORD=

# ===== Опциональные (есть разумные дефолты) =====
LOG_LEVEL=INFO
DEFAULT_QUERIES_LIMIT=5
MAX_RESULTS_PER_QUERY=50
MAX_ENRICH_LEADS=50
ENRICH_CONCURRENCY=5
HTTP_RETRIES=3
HTTP_RETRY_BASE_DELAY=0.7
