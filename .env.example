# ===== Обязательные =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/convioo
GOOGLE_PLACES_API_KEY=replace_me

# ===== Рекомендуется (без ключа Anthropic используется fallback-режим) =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ===== Доступ =====
# Когда задано, регистрация на сайте требует ввода этого кода.
# Пусто = регистрация открыта (dev-режим).
REGISTRATION_PASSWORD=

# ===== Stripe (биллинг). Пусто = эндпоинты /api/v1/billing/* отвечают 503. =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=
STRIPE_TRIAL_DAYS=14

# ===== Gmail OAuth (отправка писем от имени пользователя). =====
# Получить creds: https://console.cloud.google.com/apis/credentials
# Включить scope: https://www.googleapis.com/auth/gmail.send
# REDIRECT_URI должен совпадать с тем что зарегистрирован в Google Cloud.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://convioo.com/api/v1/oauth/gmail/callback

# ===== Опциональные (есть разумные дефолты) =====
LOG_LEVEL=INFO
DEFAULT_QUERIES_LIMIT=5
MAX_RESULTS_PER_QUERY=50
MAX_ENRICH_LEADS=50
ENRICH_CONCURRENCY=5
HTTP_RETRIES=3
HTTP_RETRY_BASE_DELAY=0.7
