# =============================================================================
# RAILWAY — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env for local dev. On Railway set each key in Variables.
# =============================================================================

# =============================================================================
# ОБЯЗАТЕЛЬНЫЕ (без них API не стартует)
# =============================================================================

# PostgreSQL — Railway автоматически предоставляет эту переменную.
# Для локальной разработки создай БД вручную.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/convioo

# Google Places API (New) — без ключа поиск молча возвращает 0 результатов.
# Получить: https://console.cloud.google.com/apis/credentials
# Включить API: "Places API (New)" в Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# JWT-подписи сессий. Сгенерировать:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ОБЯЗАТЕЛЬНО установить в Railway, иначе сессии не работают.
AUTH_JWT_SECRET=

# =============================================================================
# AI — ANTHROPIC
# =============================================================================

# Claude API ключ — без него Henry и AI-анализ не работают.
# Получить: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# Модель. Менять не нужно — дефолт оптимален.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# =============================================================================
# БЕЗОПАСНОСТЬ
# =============================================================================

# Fernet-ключ для шифрования токенов Notion / Gmail OAuth в БД.
# Сгенерировать ОДИН РАЗ и сохранить в Railway:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВНИМАНИЕ: при смене ключа все сохранённые интеграции перестанут работать.
FERNET_KEY=

# Пароль-инвайт для регистрации. Пусто = регистрация открыта (локальная разработка).
# Установи в Railway чтобы закрыть продакшн от случайных регистраций.
REGISTRATION_PASSWORD=

# =============================================================================
# CORS + ДОСТУП
# =============================================================================

# Разрешённые Origin для CORS. Укажи домен Vercel (и кастомный домен если есть).
# Пример: https://convioo.com,https://convioo-web-abc123.vercel.app
WEB_CORS_ORIGINS=https://convioo.com

# Опциональный глобальный API-ключ (X-API-Key заголовок). Пусто = не требуется.
WEB_API_KEY=

# =============================================================================
# EMAIL (Resend)
# =============================================================================

# Resend API ключ — без него верификация и письма логируются, но не отправляются.
# Получить: https://resend.com/api-keys
RESEND_API_KEY=

# Отправитель. Домен должен быть верифицирован в Resend.
EMAIL_FROM=Convioo <[email protected]>

# Публичный URL приложения (Vercel). Используется в ссылках верификации и инвайтов.
# ОБЯЗАТЕЛЬНО установить в Railway — иначе все ссылки ведут на localhost.
PUBLIC_APP_URL=https://convioo.com

# =============================================================================
# STRIPE (биллинг)
# Все четыре ключа обязательны для работы. Пусто → /api/v1/billing/* отдаёт 503.
# =============================================================================

# Получить: https://dashboard.stripe.com/apikeys (используй TEST ключи для разработки)
STRIPE_SECRET_KEY=

# Создать в Stripe Dashboard → Webhooks. URL: https://<railway-url>/api/v1/billing/webhook
# События: checkout.session.completed, customer.subscription.created/updated/deleted,
#          invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=

# ID тарифных планов из Stripe Dashboard → Products.
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

# Дней бесплатного триала для новых пользователей.
STRIPE_TRIAL_DAYS=14

# =============================================================================
# GMAIL OAUTH (отправка писем от имени пользователя)
# Пусто → /api/v1/oauth/gmail/* отдаёт 503.
# =============================================================================

# Получить: https://console.cloud.google.com/apis/credentials
# Тип: OAuth 2.0 Client ID (Web application)
# Включить scope: https://www.googleapis.com/auth/gmail.send
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ДОЛЖЕН совпадать с URI зарегистрированным в Google Cloud Console.
GOOGLE_OAUTH_REDIRECT_URI=https://convioo.com/api/v1/oauth/gmail/callback

# =============================================================================
# ИСТОЧНИКИ ДАННЫХ (multi-source коллекторы)
# =============================================================================

# Yelp Fusion — сильное покрытие US/CA/UK, 5k запросов/день бесплатно.
# Получить: https://docs.developer.yelp.com/docs/fusion-authentication
YELP_API_KEY=
YELP_ENABLED=true

# Foursquare Places v3 — глобальное покрытие, 950 запросов/день бесплатно.
# Получить: https://foursquare.com/developers
FSQ_API_KEY=
FSQ_ENABLED=true

# OpenStreetMap (Nominatim + Overpass) — бесплатно, ключ не нужен.
# Установи OSM_ENABLED=false если Overpass начинает тормозить.
OSM_ENABLED=true

# =============================================================================
# SENTRY (мониторинг ошибок)
# Пусто → SDK не инициализируется, нулевой оверхед.
# =============================================================================

# Создать проект "convioo-api" (Python) на https://sentry.io
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# ОЧЕРЕДЬ (Redis + arq)
# Опционально. Пусто → поиски выполняются inline в API-процессе (ок для dev).
# =============================================================================

# Railway Redis URL. Когда задан — поиски уходят в arq-воркер.
# Воркер запускается отдельным Railway-сервисом:
#   arq leadgen.queue.worker.WorkerSettings
REDIS_URL=

# Отключить in-process scheduler (нужно когда запущено несколько реплик API
# и воркер уже обрабатывает задания через Redis).
# SAVED_SEARCH_SCHEDULER=0

# =============================================================================
# БИЛЛИНГ-КОНТРОЛЬ
# =============================================================================

# Квоты. False = лимиты не применяются (текущий режим — продукт ещё не монетизирован).
# Установи BILLING_ENFORCED=true после успешного теста Stripe-вебхуков.
BILLING_ENFORCED=false

# =============================================================================
# СЕССИИ
# =============================================================================

# Время жизни сессии в днях (дефолт 30 дней).
AUTH_SESSION_DAYS=30

# =============================================================================
# ТЮНИНГ (есть разумные дефолты, менять не обязательно)
# =============================================================================

LOG_LEVEL=INFO
# Формат логов: json (продакшн, Railway парсит) или text (локальная разработка).
LOG_FORMAT=json

DEFAULT_QUERIES_LIMIT=5
MAX_RESULTS_PER_QUERY=50
MAX_ENRICH_LEADS=50
ENRICH_CONCURRENCY=5
HTTP_RETRIES=3
HTTP_RETRY_BASE_DELAY=0.7
