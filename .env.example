# ===== Обязательные =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/convioo
GOOGLE_PLACES_API_KEY=replace_me

# ===== Рекомендуется (без ключа Anthropic используется fallback-режим) =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ===== Доступ =====
# Когда задано, регистрация на сайте требует ввода этого кода.
# Пусто = регистрация открыта (dev-режим).
REGISTRATION_PASSWORD=

# ===== Опциональные (есть разумные дефолты) =====
LOG_LEVEL=INFO
DEFAULT_QUERIES_LIMIT=5
MAX_RESULTS_PER_QUERY=50
MAX_ENRICH_LEADS=50
ENRICH_CONCURRENCY=5
HTTP_RETRIES=3
HTTP_RETRY_BASE_DELAY=0.7

# ===== Email (Resend) =====
# Без ключа /auth/register работает, но письма не доходят (только лог).
RESEND_API_KEY=
# Должно использовать домен, верифицированный в Resend (SPF + DKIM).
EMAIL_FROM=Convioo <[email protected]>
# Используется для ссылок верификации; должен указывать на frontend.
PUBLIC_APP_URL=http://localhost:3000

# ===== Google OAuth (Gmail send) =====
# Создаются в Google Cloud Console → APIs & Services → Credentials.
# Без обоих параметров кнопка Connect в /app/settings будет неактивной.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 32 байта в Fernet-формате (base64url). Сгенерировать:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_OAUTH_TOKEN_KEY=
# Публичный URL FastAPI-бэкенда — должен совпадать с тем что указан
# в OAuth client redirect URI в Google Cloud Console.
PUBLIC_API_URL=

# ===== Web admin =====
# Когда задан, gateит /api/v1/admin/email/test и SSE.
WEB_API_KEY=
WEB_CORS_ORIGINS=
