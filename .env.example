# ===== Обязательные =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/convioo
GOOGLE_PLACES_API_KEY=replace_me

# ===== AI =====
# Без ключа — heuristic fallback (без AI-скоринга).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ===== Безопасность =====
# Генерировать: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=replace_me_with_64_hex_chars
# Генерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace_me_with_fernet_key
AUTH_SESSION_DAYS=30

# ===== Публичный URL =====
PUBLIC_APP_URL=https://convioo.com
WEB_CORS_ORIGINS=https://convioo.com
# Когда задано — каждый запрос к API требует этот ключ.
WEB_API_KEY=

# ===== Доступ =====
# Когда задано — регистрация требует этот код. Пусто = открытая.
REGISTRATION_PASSWORD=

# ===== Email (Resend) =====
RESEND_API_KEY=
EMAIL_FROM=noreply@convioo.com

# ===== Stripe. Пусто = /api/v1/billing/* отвечают 503. =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=
STRIPE_TRIAL_DAYS=14
# Включить квоты после smoke-теста Stripe.
BILLING_ENFORCED=false

# ===== Gmail OAuth (send + reply tracking) =====
# Scopes: gmail.send + gmail.readonly
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://convioo.com/api/v1/oauth/gmail/callback

# ===== Outlook OAuth =====
# Azure → App registrations. Scopes: Mail.Send + Mail.Read (delegated, multi-tenant)
OUTLOOK_OAUTH_CLIENT_ID=
OUTLOOK_OAUTH_CLIENT_SECRET=
OUTLOOK_OAUTH_REDIRECT_URI=https://convioo.com/api/v1/oauth/outlook/callback

# ===== HubSpot OAuth =====
# https://app.hubspot.com/developer. Scopes: crm.objects.contacts.write + .read
HUBSPOT_OAUTH_CLIENT_ID=
HUBSPOT_OAUTH_CLIENT_SECRET=
HUBSPOT_OAUTH_REDIRECT_URI=https://convioo.com/api/v1/oauth/hubspot/callback

# ===== Pipedrive OAuth =====
# https://pipedrive.com/developers. Scope: base
PIPEDRIVE_OAUTH_CLIENT_ID=
PIPEDRIVE_OAUTH_CLIENT_SECRET=
PIPEDRIVE_OAUTH_REDIRECT_URI=https://convioo.com/api/v1/oauth/pipedrive/callback

# ===== Notion OAuth =====
# https://www.notion.so/my-integrations → Public integration
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=https://convioo.com/api/v1/integrations/notion/callback

# ===== Slack Webhook =====
# Incoming webhook URL from Slack workspace settings. Sends notifications for hot leads and won deals.
SLACK_WEBHOOK_URL=

# ===== Дополнительные источники лидов =====
YELP_API_KEY=
YELP_ENABLED=true
FSQ_API_KEY=
FSQ_ENABLED=true
OSM_ENABLED=true

# ===== Queue (Redis + arq) =====
# Без REDIS_URL поиск запускается inline (dev fallback).
REDIS_URL=
# Установить в 0 при нескольких API-репликах без Redis.
SAVED_SEARCH_SCHEDULER=1

# ===== Sentry. Пусто = SDK не инициализируется. =====
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== Опциональные =====
LOG_LEVEL=INFO
DEFAULT_QUERIES_LIMIT=5
MAX_RESULTS_PER_QUERY=50
MAX_ENRICH_LEADS=50
ENRICH_CONCURRENCY=5
HTTP_RETRIES=3
HTTP_RETRY_BASE_DELAY=0.7
